@api = http://127.0.0.1:18080
@worker = http://127.0.0.1:18090
@project_id = replace-project-id
@dataset_id = replace-dataset-id
@version_id = replace-version-id
@job_id = replace-job-id
@request_id = replace-request-id
@plan_id = replace-plan-id
@execution_id = replace-execution-id
@execution_id_to = replace-execution-id-to
@step_id = replace-step-id
@cluster_id = replace-cluster-id
@profile_build_id = replace-profile-build-id
@scenario_id = replace-scenario-id
@draft_id = replace-draft-id

### Control plane health
GET {{api}}/health

### Runtime status
GET {{api}}/runtime_status

### Python worker health
GET {{worker}}/health

### OpenAPI
GET {{api}}/openapi.yaml

### Global prompts by operation
GET {{api}}/prompts?operation=prepare

### Prompt catalog
GET {{api}}/prompt_catalog

### Dataset profiles
GET {{api}}/dataset_profiles

### Create project
POST {{api}}/projects
Content-Type: application/json

{
  "name": "local-api-test",
  "description": "local.http test"
}

### List projects
GET {{api}}/projects

### Get project
GET {{api}}/projects/{{project_id}}

### Delete project
DELETE {{api}}/projects/{{project_id}}

### Create dataset
POST {{api}}/projects/{{project_id}}/datasets
Content-Type: application/json

{
  "name": "sns-data",
  "description": "SNS sample dataset",
  "data_type": "unstructured",
  "metadata": {
    "doc_genuineness": {
      "subject_type": "festival",
      "subject_name": "강릉 국가유산야행",
      "subject_aliases": ["문화유산야행", "문화재야행", "강릉야행"],
      "recruitment_keywords": ["서포터즈", "푸드트럭"]
    }
  }
}

### List datasets
GET {{api}}/projects/{{project_id}}/datasets

### Get dataset
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}

### Update dataset metadata
PATCH {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/metadata
Content-Type: application/json

{
  "metadata": {
    "doc_genuineness": {
      "subject_type": "festival",
      "subject_name": "강릉 국가유산야행",
      "subject_aliases": ["강릉야행"],
      "recruitment_keywords": ["서포터즈", "푸드트럭"]
    }
  }
}

### Delete dataset
DELETE {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}

### Upload dataset version
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/uploads
Content-Type: multipart/form-data; boundary=local-boundary

--local-boundary
Content-Disposition: form-data; name="metadata"

{"text_columns":["제목","본문"],"clean_preprocess_options":{"remove_english":false,"remove_numbers":false,"remove_special":false,"remove_monosyllables":true}}
--local-boundary
Content-Disposition: form-data; name="activate_on_create"

true
--local-boundary
Content-Disposition: form-data; name="prepare_required"

false
--local-boundary
Content-Disposition: form-data; name="sentiment_required"

false
--local-boundary
Content-Disposition: form-data; name="embedding_required"

false
--local-boundary
Content-Disposition: form-data; name="file"; filename="sample.csv"
Content-Type: text/csv

제목,본문
테스트 제목,테스트 본문입니다
--local-boundary--

### List dataset versions
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions

### Get dataset version
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}

### Activate dataset version
PUT {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/active_version
Content-Type: application/json

{
  "dataset_version_id": "{{version_id}}"
}

### Clear active dataset version (PUT with empty dataset_version_id)
PUT {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/active_version
Content-Type: application/json

{
  "dataset_version_id": ""
}

### Source download
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/source_download

### Clean job
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/clean
Content-Type: application/json

{
  "text_columns": ["제목", "본문"],
  "preprocess_options": {
    "remove_english": false,
    "remove_numbers": false,
    "remove_special": false,
    "remove_monosyllables": true
  },
  "force": true
}

### Clean download
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/clean_download

### Prepare sample
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/prepare_sample
Content-Type: application/json

{
  "text_columns": ["cleaned_text"],
  "max_rows": 10,
  "batch_size": 5
}

### Prepare job
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/prepare
Content-Type: application/json

{
  "max_rows": 100,
  "force": true
}

### Sentiment sample
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/sentiment_sample
Content-Type: application/json

{
  "text_columns": ["normalized_text"],
  "max_rows": 10,
  "batch_size": 5
}

### Sentiment job
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/sentiment
Content-Type: application/json

{
  "text_columns": ["normalized_text"],
  "force": true
}

### Embedding job
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/embeddings
Content-Type: application/json

{
  "text_column": "normalized_text",
  "force": true
}

### Cluster job
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/cluster
Content-Type: application/json

{
  "force": true
}

### Build jobs
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/build_jobs

### Build job detail
GET {{api}}/projects/{{project_id}}/dataset_build_jobs/{{job_id}}

### Cluster members
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/clusters/{{cluster_id}}/members?limit=50&samples_only=false

### Analyze dataset (creates a new analysis thread)
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/analyze
Content-Type: application/json

{
  "user_question": "주요 불만 이슈를 요약해줘"
}

### Create analysis thread
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/analysis_threads
Content-Type: application/json

{
  "title": "불만 이슈 분석"
}

### List analysis threads
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/analysis_threads

### Get analysis thread
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/analysis_threads/{{thread_id}}

### Ask follow-up in analysis thread
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/analysis_threads/{{thread_id}}/messages
Content-Type: application/json

{
  "content": "그중 긍정 리뷰만 보면?"
}

### Get analysis run
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/analysis_runs/{{run_id}}

### Create scenario
POST {{api}}/projects/{{project_id}}/scenarios
Content-Type: application/json

{
  "scenario_id": "S1",
  "planning_mode": "strict",
  "user_query": "주요 불만 이슈를 요약해줘",
  "query_type": "이슈 요약",
  "interpretation": "고객 불만의 주요 주제와 근거를 요약한다",
  "analysis_scope": "선택한 dataset version",
  "steps": [
    {
      "step": 1,
      "function_name": "가비지 필터링",
      "runtime_skill_name": "garbage_filter",
      "result_description": "분석 대상 텍스트 정제"
    },
    {
      "step": 2,
      "function_name": "전체 담론 요약",
      "runtime_skill_name": "issue_evidence_summary",
      "result_description": "주요 이슈와 근거 요약"
    }
  ]
}

### List scenarios
GET {{api}}/projects/{{project_id}}/scenarios

### Get scenario
GET {{api}}/projects/{{project_id}}/scenarios/{{scenario_id}}

### Create scenario plan
POST {{api}}/projects/{{project_id}}/scenarios/{{scenario_id}}/plans
Content-Type: application/json

{
  "dataset_id": "{{dataset_id}}",
  "goal": "주요 불만 이슈를 요약해줘",
  "constraints": [],
  "context": {}
}

### Execute scenario
POST {{api}}/projects/{{project_id}}/scenarios/{{scenario_id}}/execute
Content-Type: application/json

{
  "dataset_id": "{{dataset_id}}",
  "goal": "주요 불만 이슈를 요약해줘",
  "constraints": [],
  "context": {}
}

### Create report draft
POST {{api}}/projects/{{project_id}}/report_drafts
Content-Type: application/json

{
  "title": "주요 VOC 보고서 초안",
  "execution_ids": ["{{execution_id}}"]
}

### Get report draft
GET {{api}}/projects/{{project_id}}/report_drafts/{{draft_id}}

### -----------------------------------------------------------------
### 5/12 (silverone) document_cluster_profile build skill + 운영자 confirm
### Codex 검토 round-2 finding (1)~(4) 반영
### -----------------------------------------------------------------

### 1. POST document_cluster_profile (profile build trigger)
### clean ready 필수. 매 호출은 새 UUID profile_build_id 발급 + 별도 immutable row.
### fastembed + KMeans + claude-haiku-4-5 auto_label. 동기 ~40초.
### 응답에서 "id" 값을 잡아 다음 PUT의 profile_build_id로 echo.
POST {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/document_cluster_profile
Content-Type: application/json

{
  "n_clusters": 4,
  "target_domain": "강릉문화재야행 festival"
}

### 2. GET document_cluster_profile (read model — latest build + 그 build에 묶인 latest confirmation)
### 응답의 profile_build_id를 PUT 시 그대로 echo. rebuild가 끼면 새 build_id로 바뀜.
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/document_cluster_profile

### 3. PUT document_cluster_profile/confirmations (운영자 일괄 결정, append-only)
### Codex finding 2~4 — profile_build_id required + status=ready + cluster_id valid set 검증.
### 동일 결정은 noop, 변경 시 supersedes_id chain. pending/missing은 select가 기본 exclude.
PUT {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/versions/{{version_id}}/document_cluster_profile/confirmations
Content-Type: application/json

{
  "profile_build_id": "{{profile_build_id}}",
  "confirmed_by": "silverone",
  "confirmations": {
    "0": { "operator_action": "exclude", "confirm_note": "공식 홍보/안내" },
    "1": { "operator_action": "pending", "confirm_note": "재검토 필요" },
    "2": { "operator_action": "include", "confirm_note": "진짜 후기" },
    "3": { "operator_action": "exclude", "confirm_note": "전국 축제 카탈로그" }
  }
}

### 4. GET cluster_confirmation_history (read-only 참고 catalog — 자동 적용 X)
GET {{api}}/projects/{{project_id}}/datasets/{{dataset_id}}/cluster_confirmation_history
