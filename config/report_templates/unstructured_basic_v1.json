{
  "template_id": "unstructured_basic_v1",
  "name": "비정형 기초 분석 보고서",
  "data_type": "unstructured",
  "report_title": "데이터 기초 분석 보고서",
  "note": "DRAFT. 섹션을 추가/삭제/순서변경하려면 sections 배열만 수정. panel.view/width/value_format/source로 배치·표현·출처 결정. 엔진은 각 section의 required_build가 ready일 때만 생성하고, 아니면 missing_sections에 기록. (출처는 응답 블록엔 안 실음 — report.dataset_version_id + section_id로 추적.)",

  "sections": [
    {
      "id": "analysis_overview",
      "title": "분석 개요",
      "required_build": "clean",
      "layout": [
        { "panels": [
          { "view": "stat_grid", "width": "full",
            "items": [
              { "key": "dataset", "label": "데이터셋", "format": "text", "source": { "build": "version", "path": "dataset_name" }, "sub_source": { "build": "version", "path": "version_label" } },
              { "key": "period",  "label": "분석 기간", "format": "text", "source": { "build": "version", "path": "data_period" } },
              { "key": "model",   "label": "분석 모델", "format": "code", "source": { "build": "version", "path": "lloa_model" } },
              { "key": "unit",    "label": "분석 단위", "format": "text", "value": "문서 · 절(clause)" },
              { "key": "steps",   "label": "전처리 단계", "format": "text", "value": "정제 · 진성 · 절 라벨링" }
            ]
          }
        ] }
      ]
    },

    {
      "id": "doc_overview",
      "title": "문서 개요",
      "required_build": "doc_genuineness",
      "layout": [
        { "panels": [
          { "view": "stat_grid", "width": "full",
            "items": [
              { "key": "genuine_docs", "label": "진성 문서수", "format": "count", "unit": "건", "source": { "build": "doc_genuineness", "path": "summary.genuineness.genuine_review" } },
              { "key": "clauses",      "label": "절(clause) 수", "format": "count", "unit": "개", "source": { "build": "clause_label", "path": "summary.total" } }
            ]
          }
        ] }
      ]
    },

    {
      "id": "channel_distribution",
      "title": "채널별 진성 문서 분포",
      "required_build": "channel_breakdown",
      "unit_basis": "doc",
      "layout": [
        { "panels": [
          { "view": "bar",   "width": "2/3", "value_format": "count", "source": { "build": "channel_breakdown", "path": "summary.channels", "top": 8 } },
          { "view": "table", "width": "1/3", "source": { "build": "channel_breakdown", "path": "summary.channels", "top": 8 } }
        ] }
      ]
    },

    {
      "id": "sentiment_distribution",
      "title": "절 단위 감성 분포",
      "required_build": "clause_label",
      "unit_basis": "clause",
      "layout": [
        { "panels": [
          { "view": "doughnut", "width": "2/3", "value_format": "percent", "source": { "build": "clause_label", "path": "summary.sentiment", "order": ["positive", "neutral", "negative"] } },
          { "view": "table",    "width": "1/3", "source": { "build": "clause_label", "path": "summary.sentiment", "order": ["positive", "neutral", "negative"] } }
        ] }
      ]
    },

    {
      "id": "aspect_distribution",
      "title": "유형별 절 분포",
      "required_build": "clause_label",
      "unit_basis": "clause",
      "layout": [
        { "panels": [
          { "view": "bar",   "width": "2/3", "value_format": "count", "source": { "build": "clause_label", "path": "summary.aspect", "order_by": "count" } },
          { "view": "table", "width": "1/3", "source": { "build": "clause_label", "path": "summary.aspect", "order_by": "count" } }
        ] }
      ]
    },

    {
      "id": "aspect_sentiment",
      "title": "유형별 감성 구성·대비",
      "required_build": "clause_label",
      "unit_basis": "clause",
      "layout": [
        { "panels": [
          { "view": "stacked_bar", "width": "full", "value_format": "percent", "title": "긍정·부정 구성비 (100%)", "source": { "build": "clause_label", "path": "summary.aspect_sentiment" } }
        ] },
        { "panels": [
          { "view": "rank", "width": "1/2", "value_format": "count", "title": "긍정 많은 유형", "source": { "build": "clause_label", "path": "summary.aspect_sentiment", "order_by": "positive", "top": 6 } },
          { "view": "rank", "width": "1/2", "value_format": "count", "title": "부정 많은 유형", "source": { "build": "clause_label", "path": "summary.aspect_sentiment", "order_by": "negative", "top": 6 } }
        ] }
      ]
    },

    {
      "id": "keyword_distribution",
      "title": "감성별 상위 키워드",
      "required_build": "clause_keywords",
      "unit_basis": "clause",
      "layout": [
        { "panels": [
          { "view": "rank", "width": "1/2", "value_format": "count", "title": "긍정 키워드", "source": { "build": "clause_keywords", "path": "summary.top_keywords_positive", "top": 10 } },
          { "view": "rank", "width": "1/2", "value_format": "count", "title": "부정 키워드", "source": { "build": "clause_keywords", "path": "summary.top_keywords_negative", "top": 10 } }
        ] }
      ]
    }
  ]
}
