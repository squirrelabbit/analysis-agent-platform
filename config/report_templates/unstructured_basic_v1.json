{
  "template_id": "unstructured_basic_v1",
  "name": "비정형 기초 분석 보고서",
  "data_type": "unstructured",
  "report_title": "데이터 기초 분석 보고서",
  "note": "섹션을 추가/삭제/순서변경하려면 sections만 수정. 값은 metric 이름으로 고른다(예: {\"label\":\"진성 문서수\",\"metric\":\"genuine_docs_total\"}). 사용 가능한 metric 목록은 config/report_metrics.json 또는 docs/api/report_metrics.md 참고. 차트는 view/width + metric + order/order_by/top 옵션. metric에 없는 값은 source(build+path)로 직접 지정 가능(고급).",

  "sections": [
    {
      "id": "analysis_overview",
      "title": "분석 개요",
      "required_build": "clean",
      "layout": [
        { "panels": [
          { "view": "stat_grid", "width": "full",
            "items": [
              { "key": "dataset", "label": "데이터셋", "format": "text", "source": { "build": "version", "path": "dataset_name" }, "sub_source": { "build": "version", "path": "version_label" } },
              { "key": "period",  "label": "분석 기간", "format": "text", "source": { "build": "version", "path": "data_period" } },
              { "key": "model",   "label": "분석 모델", "format": "code", "source": { "build": "version", "path": "lloa_model" } },
              { "key": "unit",    "label": "분석 단위", "format": "text", "value": "문서 · 절(clause)" },
              { "key": "steps",   "label": "전처리 단계", "format": "text", "value": "정제 · 진성 · 절 라벨링" }
            ]
          }
        ] }
      ]
    },

    {
      "id": "doc_overview",
      "title": "문서 개요",
      "required_build": "doc_genuineness",
      "layout": [
        { "panels": [
          { "view": "stat_grid", "width": "full",
            "items": [
              { "label": "진성 문서수 (전체)",      "metric": "genuine_docs_total" },
              { "label": "진성 문서수 (최근연도)",   "metric": "genuine_docs_recent_year" },
              { "label": "절(clause) 수 (전체)",    "metric": "clauses_total" },
              { "label": "절(clause) 수 (최근연도)", "metric": "clauses_recent_year" }
            ]
          }
        ] }
      ]
    },

    {
      "id": "channel_distribution",
      "title": "채널별 진성 문서 분포",
      "required_build": "channel_breakdown",
      "unit_basis": "doc",
      "date_filter": "recent_year",
      "layout": [
        { "panels": [
          { "view": "bar",   "width": "2/3", "metric": "channel_genuine_distribution", "top": 8 },
          { "view": "table", "width": "1/3", "metric": "channel_genuine_distribution", "top": 8 }
        ] }
      ]
    },

    {
      "id": "sentiment_distribution",
      "title": "절 단위 감성 분포",
      "required_build": "clause_label",
      "unit_basis": "clause",
      "date_filter": "recent_year",
      "layout": [
        { "panels": [
          { "view": "doughnut", "width": "full", "metric": "sentiment_distribution", "order": ["positive", "neutral", "negative"] }
        ]},
        { "panels": [  
          { "view": "table",    "width": "full", "metric": "sentiment_distribution", "order": ["positive", "neutral", "negative"] }
        ] }
      ]
    },

    {
      "id": "aspect_distribution",
      "title": "유형별 절 분포",
      "required_build": "clause_label",
      "unit_basis": "clause",
      "date_filter": "recent_year",
      "layout": [
        { "panels": [
          { "view": "bar",   "width": "full", "metric": "aspect_distribution", "order_by": "count" }
        ]},
        { "panels": [           
          { "view": "table", "width": "full", "metric": "aspect_distribution", "order_by": "count" }
        ] }
      ]
    },

    {
      "id": "aspect_sentiment",
      "title": "유형별 감성 구성·대비",
      "required_build": "clause_label",
      "unit_basis": "clause",
      "date_filter": "recent_year",
      "layout": [
        { "panels": [
          { "view": "stacked_bar", "width": "full", "metric": "aspect_sentiment", "title": "긍정·부정 구성비 (100%)" }
        ] },
        { "panels": [
          { "view": "rank", "width": "1/2", "metric": "aspect_sentiment", "value_format": "count", "order_by": "positive", "top": 6, "title": "긍정 많은 유형" },
          { "view": "rank", "width": "1/2", "metric": "aspect_sentiment", "value_format": "count", "order_by": "negative", "top": 6, "title": "부정 많은 유형" }
        ] }
      ]
    },

    {
      "id": "keyword_distribution",
      "title": "감성별 상위 키워드",
      "required_build": "clause_keywords",
      "unit_basis": "clause",
      "date_filter": "recent_year",
      "layout": [
        { "panels": [
          { "view": "rank", "width": "1/2", "metric": "keywords_positive", "top": 10, "title": "긍정 키워드" },
          { "view": "rank", "width": "1/2", "metric": "keywords_negative", "top": 10, "title": "부정 키워드" }
        ] }
      ]
    }
  ]
}
