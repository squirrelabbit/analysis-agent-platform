  "skills": [
    {
      "name": "structured_kpi_summary",
      "description": "Summarize structured KPI metrics.",
      "engine": "duckdb",
      "kind": "plan",
      "category": "structured_core",
      "plan_enabled": true,
      "dataset_source": "request",
      "default_inputs": {
        "time_column": "date",
        "metric_column": "value"
      }
    },
    {
      "name": "document_filter",
      "description": "Filter documents before downstream analysis steps.",
      "engine": "python-ai",
      "kind": "plan",
      "category": "unstructured_support",
      "plan_enabled": true,
      "task_path": "/tasks/document_filter",
      "dataset_source": "prepared",
      "requires_prepare": true,
      "goal_input": "query",
      "default_inputs": {
        "text_column": "text",
        "sample_n": 5
      }
    },
    {
      "name": "deduplicate_documents",
      "description": "Collapse near-duplicate documents into canonical rows.",
      "engine": "python-ai",
      "kind": "plan",
      "category": "unstructured_support",
      "plan_enabled": true,
      "task_path": "/tasks/deduplicate_documents",
      "dataset_source": "prepared",
      "requires_prepare": true,
      "default_inputs": {
        "text_column": "text",
        "sample_n": 3,
        "duplicate_threshold": 0.85
      }
    },
    {
      "name": "keyword_frequency",
      "description": "Count top keywords from filtered unstructured rows.",
      "engine": "python-ai",
      "kind": "plan",
      "category": "unstructured_support",
      "plan_enabled": true,
      "task_path": "/tasks/keyword_frequency",
      "dataset_source": "prepared",
      "requires_prepare": true,
      "default_inputs": {
        "text_column": "text",
        "top_n": 10
      }
    },
    {
      "name": "time_bucket_count",
      "description": "Aggregate filtered issue rows by time bucket.",
      "engine": "python-ai",
      "kind": "plan",
      "category": "unstructured_support",
      "plan_enabled": true,
      "task_path": "/tasks/time_bucket_count",
      "dataset_source": "prepared",
      "requires_prepare": true,
      "metadata_defaults": {
        "time_column": "time_column",
        "bucket": "time_bucket"
      },
      "default_inputs": {
        "text_column": "text",
        "time_column": "occurred_at",
        "bucket": "day",
        "top_n": 5,
        "sample_n": 3
      }
    },
    {
      "name": "meta_group_count",
      "description": "Aggregate filtered issue rows by metadata group.",
      "engine": "python-ai",
      "kind": "plan",
      "category": "unstructured_support",
      "plan_enabled": true,
      "task_path": "/tasks/meta_group_count",
      "dataset_source": "prepared",
      "requires_prepare": true,
      "metadata_defaults": {
        "dimension_column": "breakdown_column"
      },
      "default_inputs": {
        "text_column": "text",
        "dimension_column": "channel",
        "top_n": 5,
        "sample_n": 3
      }
    },
    {
      "name": "document_sample",
      "description": "Select representative documents for downstream summaries.",
      "engine": "python-ai",
      "kind": "plan",
      "category": "unstructured_support",
      "plan_enabled": true,
      "task_path": "/tasks/document_sample",
      "dataset_source": "prepared",
      "requires_prepare": true,
      "goal_input": "query",
      "default_inputs": {
        "text_column": "text",
        "sample_n": 3
      }
    },
    {
      "name": "dictionary_tagging",
      "description": "Assign deterministic taxonomy tags to filtered text rows.",
      "engine": "python-ai",
      "kind": "plan",
      "category": "unstructured_support",
      "plan_enabled": true,
      "task_path": "/tasks/dictionary_tagging",
      "dataset_source": "prepared",
      "requires_prepare": true,
      "default_inputs": {
        "text_column": "text",
        "top_n": 5,
        "sample_n": 3,
        "max_tags_per_document": 3
