    {
      "name": "embedding_cluster",
      "description": "Cluster filtered embedding records into issue groups.",
      "engine": "python-ai",
      "kind": "plan",
      "category": "unstructured_support",
      "plan_enabled": true,
      "task_path": "/tasks/embedding_cluster",
      "dataset_source": "prepared",
      "requires_prepare": true,
      "requires_embedding": true,
      "default_inputs": {
        "sample_n": 3,
        "top_n": 5,
        "cluster_similarity_threshold": 0.3
      }
    },
    {
      "name": "cluster_label_candidates",
      "description": "Generate deterministic label candidates for clusters.",
      "engine": "python-ai",
      "kind": "plan",
      "category": "unstructured_support",
      "plan_enabled": true,
      "task_path": "/tasks/cluster_label_candidates",
      "dataset_source": "request",
      "default_inputs": {
        "top_n": 5,
        "sample_n": 3
